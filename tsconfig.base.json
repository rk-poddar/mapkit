{
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@map-kit/core": ["packages/core/src/index.ts"],
      "@map-kit/google-maps": ["packages/google-maps/src/index.ts"],
      "@map-kit/leaflet": ["packages/leaflet/src/index.ts"],
      "@map-kit/mapbox": ["packages/mapbox/src/index.ts"],
      "@map-kit/maplibre": ["packages/maplibre/src/index.ts"],
      "@map-kit/react": ["packages/react/src/index.ts"]
    }
  }
}
