{
  "name": "mapkit",
  "version": "0.0.0",
  "private": true,
  "description": "A React and Next.js map UI kit with adapter support for Leaflet, MapLibre, Google Maps, and Mapbox.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r --filter './packages/*' build && pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.8"
  }
}
