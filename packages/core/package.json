{
  "name": "@map-kit/core",
  "version": "0.0.0",
  "private": true,
  "description": "Framework-agnostic types and utilities for Map Kit.",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
